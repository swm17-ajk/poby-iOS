require "base64"
require "shellwords"
require "tmpdir"

default_platform(:ios)

PROJECT_PATH = "poby.xcodeproj"
SCHEME = "poby"
APP_IDENTIFIER = "com.poseby.poby"

def required_env(name)
  value = ENV[name]
  UI.user_error!("Missing required environment variable: #{name}") if value.to_s.strip.empty?
  value
end

def app_store_connect_key_content
  raw_content = required_env("APP_STORE_CONNECT_KEY_CONTENT")

  if ENV["APP_STORE_CONNECT_KEY_CONTENT_BASE64"] == "true"
    Base64.decode64(raw_content)
  else
    raw_content.gsub("\\n", "\n")
  end
end

def app_store_connect_key_path
  return ENV["APP_STORE_CONNECT_KEY_PATH"] unless ENV["APP_STORE_CONNECT_KEY_PATH"].to_s.strip.empty?

  key_id = required_env("APP_STORE_CONNECT_KEY_ID")
  path = File.join(Dir.tmpdir, "AuthKey_#{key_id}.p8")

  File.open(path, File::WRONLY | File::CREAT | File::TRUNC, 0o600) do |file|
    file.write(app_store_connect_key_content)
  end

  path
end

def xcodebuild_auth_args
  [
    "-allowProvisioningUpdates",
    "-authenticationKeyPath #{app_store_connect_key_path.shellescape}",
    "-authenticationKeyID #{required_env("APP_STORE_CONNECT_KEY_ID").shellescape}",
    "-authenticationKeyIssuerID #{required_env("APP_STORE_CONNECT_ISSUER_ID").shellescape}"
  ].join(" ")
end

platform :ios do
  desc "Run unit tests"
  lane :test do
    run_tests(
      project: PROJECT_PATH,
      scheme: SCHEME,
      devices: ["iPhone 15"],
      clean: true
    )
  end

  desc "Build and upload a TestFlight build"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: required_env("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: required_env("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: app_store_connect_key_content,
      duration: 1200,
      in_house: false
    )

    setup_ci if ENV["CI"]

    build_number = ENV["BUILD_NUMBER"] || ENV["GITHUB_RUN_NUMBER"]
    build_number ||= latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0
    ) + 1

    increment_build_number(
      build_number: build_number,
      xcodeproj: PROJECT_PATH
    )

    build_app(
      project: PROJECT_PATH,
      scheme: SCHEME,
      configuration: "Release",
      clean: true,
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: "K9CY4X6X5A"
      },
      output_directory: "fastlane/build",
      output_name: "poby.ipa",
      xcargs: xcodebuild_auth_args
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
